      "bodyJs": "if (!Array.isArray(heap) || !ref || typeof ref !== 'object' || typeof ref.ref !== 'number') return 'error'; const i = ref.ref; if (i < 0 || i >= heap.length) return 'error'; const p = heap[i]; return p && typeof p === 'object' && 'object' in p ? p : 'error';"
    },
    {
      "name": "loadInt",
      "kind": "js",
      "inputTypes": [
        "List[Int]",
        "Ref[Int]"
      ],
