    ],
    "body": "if (!Array.isArray(pointHeap) || !Array.isArray(xHeap) || !Array.isArray(yHeap) || pointHeap.length <= 1) return 'error'; const p = pointHeap[1]; if (!p || typeof p !== 'object' || !('object' in p)) return 'error'; const x = p.object.fields.x; const y = p.object.fields.y; if (!x || typeof x !== 'object' || typeof x.ref !== 'number') return 'error'; if (!y || typeof y !== 'object' || typeof y.ref !== 'number') return 'error'; if (x.ref < 0 || x.ref >= xHeap.length) return 'error'; if (y.ref < 0 || y.ref >= yHeap.length) return 'error'; const xv = xHeap[x.ref]; const yv = yHeap[y.ref]; if (typeof xv !== 'number' || typeof yv !== 'number') return 'error'; return xv;"
  },
