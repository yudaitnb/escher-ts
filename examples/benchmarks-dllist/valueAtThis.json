    "body": "if (!Array.isArray(nodeHeap) || !Array.isArray(valueHeap) || !Array.isArray(nextHeap) || !Array.isArray(prevHeap)) return 'error'; if (!thisRef || typeof thisRef !== 'object' || typeof thisRef.ref !== 'number') return 'error'; const idx = thisRef.ref; if (idx < 0 || idx >= nodeHeap.length) return 'error'; const node = nodeHeap[idx]; if (!node || typeof node !== 'object' || !('object' in node)) return 'error'; const valueRef = node.object.fields.value; const nextRef = node.object.fields.next; const prevRef = node.object.fields.prev; if (!valueRef || typeof valueRef !== 'object' || typeof valueRef.ref !== 'number') return 'error'; if (!nextRef || typeof nextRef !== 'object' || typeof nextRef.ref !== 'number') return 'error'; if (!prevRef || typeof prevRef !== 'object' || typeof prevRef.ref !== 'number') return 'error'; if (valueRef.ref < 0 || valueRef.ref >= valueHeap.length) return 'error'; if (nextRef.ref !== -1 && (nextRef.ref < 0 || nextRef.ref >= nextHeap.length)) return 'error'; if (prevRef.ref !== -1 && (prevRef.ref < 0 || prevRef.ref >= prevHeap.length)) return 'error'; const v = valueHeap[valueRef.ref]; return typeof v === 'number' ? v : 'error';"
