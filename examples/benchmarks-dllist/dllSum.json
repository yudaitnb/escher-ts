    "body": "if (!Array.isArray(nodeHeap) || !Array.isArray(valueHeap) || !thisRef || typeof thisRef.ref !== 'number') return 0; let cur = thisRef.ref; if (cur === -1) return 0; if (cur < -1 || cur >= nodeHeap.length) return 0; let sum = 0; let guard = 0; const max = nodeHeap.length + 1; while (cur !== -1 && guard <= max) { if (cur < 0 || cur >= nodeHeap.length) return 0; const node = nodeHeap[cur]; if (!node || typeof node !== 'object' || !('object' in node)) return 0; const valueRef = node.object.fields.value; const nextRef = node.object.fields.next; if (!valueRef || typeof valueRef !== 'object' || typeof valueRef.ref !== 'number') return 0; if (!nextRef || typeof nextRef !== 'object' || typeof nextRef.ref !== 'number') return 0; if (valueRef.ref < 0 || valueRef.ref >= valueHeap.length) return 0; const v = valueHeap[valueRef.ref]; if (typeof v !== 'number') return 0; sum += v; cur = nextRef.ref; guard += 1; } return sum;"
